"use strict";

/*
  ESTE ARQUIVO JÁ CONTÉM AS 10 FOTOS.
  Não precisa criar pasta de imagens.
  A música usa o vídeo oficial do YouTube e começa quando a pessoa toca em
  "Entrar nos bastidores".
*/

const PHOTO_DATA = ["data:image/webp;base64,", "data:image/webp;base64,", "data:image/webp;base64,", "data:image/webp;base64,", "data:image/webp;base64,", "data:image/webp;base64,", "data:image/webp;base64,", "data:image/webp;base64,", "data:image/webp;base64,", "data:image/webp;base64,"];

const MUSIC_VIDEO_ID = "lY5V4hSLWY8";
const MUSIC_URL =
  `https://www.youtube-nocookie.com/embed/${MUSIC_VIDEO_ID}` +
  `?autoplay=1&controls=0&loop=1&playlist=${MUSIC_VIDEO_ID}` +
  `&playsinline=1&rel=0&modestbranding=1&enablejsapi=1`;

const intro = document.getElementById("intro");
const startingLights = document.getElementById("startingLights");
const introStatus = document.getElementById("introStatus");
const enterButton = document.getElementById("enterButton");
const experience = document.getElementById("experience");
const slides = [...document.querySelectorAll(".slide")];
const backButton = document.getElementById("backButton");
const nextButton = document.getElementById("nextButton");
const dotsRoot = document.getElementById("dots");
const progressFill = document.getElementById("progressFill");
const slideCounter = document.getElementById("slideCounter");
const musicButton = document.getElementById("musicButton");
const musicDock = document.getElementById("musicDock");
const musicFrame = document.getElementById("musicFrame");
const languageLine = document.getElementById("languageLine");
const finalSignature = document.getElementById("finalSignature");
const smokeCanvas = document.getElementById("smokeCanvas");

const languages = [
  "Eu te amo, irmã.",
  "Ti voglio bene, sorella mia.",
  "Volim te, sestro.",
  "मैं तुमसे प्यार करता हूँ, दीदी।",
  "Volim te, sestro.",
  "Я люблю тебя, сестрёнка.",
  "Kocham cię, siostro.",
  "我爱你，姐姐。",
  "Je t’aime, ma sœur."
];

let currentSlide = 0;
let typingTimer = null;
let languageTimer = null;
let typingComplete = false;
let currentTextTarget = null;
let currentFullText = "";
let experienceStarted = false;
let musicStarted = false;
let musicPaused = false;

function installPhotos() {
  document.querySelectorAll("[data-photo]").forEach((image) => {
    const index = Number(image.dataset.photo);
    image.src = PHOTO_DATA[index] || "";
  });
}

function createDots() {
  dotsRoot.innerHTML = slides
    .map((_, index) =>
      `<button class="dot" type="button" data-index="${index}" ` +
      `aria-label="Ir para a parte ${index + 1}"></button>`
    )
    .join("");

  dotsRoot.querySelectorAll(".dot").forEach((dot) => {
    dot.addEventListener("click", () => {
      const target = Number(dot.dataset.index);
      if (target !== currentSlide) showSlide(target);
    });
  });
}

function clearTyping() {
  if (typingTimer !== null) {
    window.clearTimeout(typingTimer);
    typingTimer = null;
  }
}

function clearLanguageSequence() {
  if (languageTimer !== null) {
    window.clearTimeout(languageTimer);
    languageTimer = null;
  }

  languageLine.classList.remove("is-falling");
  languageLine.textContent = "";
  finalSignature.classList.remove("is-visible");
}

function finishTyping() {
  clearTyping();
  typingComplete = true;

  if (currentTextTarget) {
    currentTextTarget.textContent = currentFullText;
    currentTextTarget.classList.add("is-complete");
  }

  updateNavigation();

  if (currentSlide === slides.length - 1) {
    startLanguageSequence();
  }
}

function typeText(target, text) {
  clearTyping();

  currentTextTarget = target;
  currentFullText = text;
  typingComplete = false;
  target.textContent = "";
  target.classList.remove("is-complete");

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const delay = reduceMotion ? 0 : 8;
  const chunkSize = reduceMotion ? text.length : 2;
  let position = 0;

  function typeNextChunk() {
    if (position >= text.length) {
      finishTyping();
      return;
    }

    target.textContent += text.slice(position, position + chunkSize);
    position += chunkSize;

    const shell = target.closest(".typewriter-box");
    if (shell) shell.scrollTop = shell.scrollHeight;

    typingTimer = window.setTimeout(typeNextChunk, delay);
  }

  typeNextChunk();
}

function revealCurrentText() {
  if (!typingComplete) finishTyping();
}

function startLanguageSequence() {
  clearLanguageSequence();
  let index = 0;

  function showNextLanguage() {
    if (index >= languages.length) {
      finalSignature.classList.add("is-visible");
      return;
    }

    languageLine.classList.remove("is-falling");
    void languageLine.offsetWidth;
    languageLine.textContent = languages[index];
    languageLine.classList.add("is-falling");
    index += 1;

    languageTimer = window.setTimeout(showNextLanguage, 2300);
  }

  showNextLanguage();
}

function updateNavigation() {
  backButton.disabled = currentSlide === 0;
  nextButton.disabled = !typingComplete || currentSlide === slides.length - 1;

  progressFill.style.width = `${((currentSlide + 1) / slides.length) * 100}%`;
  slideCounter.textContent =
    `PARTE ${String(currentSlide + 1).padStart(2, "0")} / ` +
    `${String(slides.length).padStart(2, "0")}`;

  dotsRoot.querySelectorAll(".dot").forEach((dot, index) => {
    dot.classList.toggle("is-active", index === currentSlide);
    dot.setAttribute("aria-current", index === currentSlide ? "step" : "false");
  });
}

function showSlide(index) {
  if (index < 0 || index >= slides.length) return;

  clearTyping();
  clearLanguageSequence();
  currentSlide = index;
  typingComplete = false;

  slides.forEach((slide, slideIndex) => {
    slide.classList.toggle("is-active", slideIndex === currentSlide);
    slide.classList.toggle("is-before", slideIndex < currentSlide);
    slide.setAttribute(
      "aria-hidden",
      slideIndex === currentSlide ? "false" : "true"
    );
  });

  updateNavigation();

  const activeSlide = slides[currentSlide];
  const source = activeSlide.querySelector(".slide-source");
  const target = activeSlide.querySelector(".typewriter-text");
  const shell = activeSlide.querySelector(".typewriter-box");

  if (shell) shell.scrollTop = 0;
  if (source && target) typeText(target, source.textContent.trim());
}

function sendMusicCommand(command) {
  if (!musicFrame.contentWindow) return;

  musicFrame.contentWindow.postMessage(
    JSON.stringify({
      event: "command",
      func: command,
      args: []
    }),
    "*"
  );
}

function startMusic() {
  if (!musicStarted) {
    musicFrame.src = MUSIC_URL;
    musicStarted = true;
    musicPaused = false;
    musicButton.textContent = "Pausar música";
    musicDock.classList.remove("is-paused");
    return;
  }

  sendMusicCommand("playVideo");
  musicPaused = false;
  musicButton.textContent = "Pausar música";
  musicDock.classList.remove("is-paused");
}

function pauseMusic() {
  sendMusicCommand("pauseVideo");
  musicPaused = true;
  musicButton.textContent = "Tocar música";
  musicDock.classList.add("is-paused");
}

function enterExperience() {
  if (experienceStarted) return;

  experienceStarted = true;
  enterButton.disabled = true;
  introStatus.textContent = "Abrindo os arquivos da nossa história...";
  startingLights.classList.add("is-launching");

  startMusic();

  window.setTimeout(() => {
    intro.classList.add("is-leaving");
    experience.hidden = false;

    window.requestAnimationFrame(() => {
      experience.classList.add("is-visible");
    });

    showSlide(0);
  }, 520);

  window.setTimeout(() => {
    intro.hidden = true;
  }, 1250);
}

enterButton.addEventListener("click", enterExperience);

backButton.addEventListener("click", () => {
  showSlide(currentSlide - 1);
});

nextButton.addEventListener("click", () => {
  if (typingComplete) showSlide(currentSlide + 1);
});

musicButton.addEventListener("click", () => {
  if (!musicStarted || musicPaused) {
    startMusic();
  } else {
    pauseMusic();
  }
});

slides.forEach((slide) => {
  const shell = slide.querySelector(".typewriter-box");
  if (!shell) return;

  shell.addEventListener("click", revealCurrentText);
  shell.addEventListener("keydown", (event) => {
    if (event.key === "Enter" || event.key === " ") {
      event.preventDefault();
      revealCurrentText();
    }
  });
});

document.addEventListener("keydown", (event) => {
  if (!experienceStarted) return;

  if (event.key === "ArrowLeft") {
    showSlide(currentSlide - 1);
  }

  if (event.key === "ArrowRight") {
    if (typingComplete) showSlide(currentSlide + 1);
    else revealCurrentText();
  }
});

function setupSmoke() {
  const context = smokeCanvas.getContext("2d");
  const particles = [];
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function resize() {
    const ratio = Math.min(window.devicePixelRatio || 1, 2);
    smokeCanvas.width = Math.floor(window.innerWidth * ratio);
    smokeCanvas.height = Math.floor(window.innerHeight * ratio);
    smokeCanvas.style.width = `${window.innerWidth}px`;
    smokeCanvas.style.height = `${window.innerHeight}px`;
    context.setTransform(ratio, 0, 0, ratio, 0, 0);
  }

  function createParticle() {
    return {
      x: window.innerWidth * (0.25 + Math.random() * 0.75),
      y: window.innerHeight + 30,
      radius: 28 + Math.random() * 90,
      speed: 0.12 + Math.random() * 0.32,
      drift: -0.22 + Math.random() * 0.44,
      alpha: 0.012 + Math.random() * 0.026
    };
  }

  function resetParticle(particle) {
    Object.assign(particle, createParticle());
  }

  for (let i = 0; i < 18; i += 1) {
    const particle = createParticle();
    particle.y = Math.random() * window.innerHeight;
    particles.push(particle);
  }

  function draw() {
    context.clearRect(0, 0, window.innerWidth, window.innerHeight);

    for (const particle of particles) {
      const gradient = context.createRadialGradient(
        particle.x,
        particle.y,
        0,
        particle.x,
        particle.y,
        particle.radius
      );

      gradient.addColorStop(0, `rgba(225, 6, 0, ${particle.alpha})`);
      gradient.addColorStop(1, "rgba(225, 6, 0, 0)");

      context.fillStyle = gradient;
      context.beginPath();
      context.arc(particle.x, particle.y, particle.radius, 0, Math.PI * 2);
      context.fill();

      if (!reduceMotion) {
        particle.y -= particle.speed;
        particle.x += particle.drift;
      }

      if (particle.y + particle.radius < 0) resetParticle(particle);
    }

    window.requestAnimationFrame(draw);
  }

  resize();
  window.addEventListener("resize", resize);
  draw();
}

installPhotos();
createDots();
setupSmoke();
updateNavigation();
